#include <stdio.h>
int main()
{
    int block[3]={100,500,200};
    int process[3]={90,150,180};
    int i,j,best;
    for(i=0;i<3;i++)
    {
        best=-1;
        for(j=0;j<3;j++)
        {
            if(block[j]>=process[i])
            {
                if(best==-1 || block[j]<block[best])
                    best=j;
            }
        }
        if(best!=-1)
        {
            printf("Process %d allocated to Block %d\n",i+1,best+1);
            block[best]-=process[i];
        }
    }
    return 0;
}
