#include <stdio.h>
int main()
{
    int alloc[5][3]={{0,1,0},{2,0,0},{3,0,2},{2,1,1},{0,0,2}};
    int max[5][3]={{7,5,3},{3,2,2},{9,0,2},{2,2,2},{4,3,3}};
    int avail[3]={3,3,2};
    int need[5][3],finish[5]={0};
    int i,j,k,count=0;
    for(i=0;i<5;i++)
        for(j=0;j<3;j++)
            need[i][j]=max[i][j]-alloc[i][j];
    printf("Safe Sequence: ");
    while(count<5)
    {
        for(i=0;i<5;i++)
        {
            if(finish[i]==0)
            {
                int flag=1;
                for(j=0;j<3;j++)
                {
                    if(need[i][j]>avail[j])
                    {
                        flag=0;
                        break;
                    }
                }
                if(flag)
                {
                    printf("P%d ",i);
                    for(k=0;k<3;k++)
                        avail[k]+=alloc[i][k];
                    finish[i]=1;
                    count++;
                }
            }
        }
    }
    return 0;
}
